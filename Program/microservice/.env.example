# ParadePaard environment configuration — copy to `.env` and fill in real values.
# `.env` is gitignored; never commit real secrets. All values below are examples/blanks.

# ---------------------------------------------------------------------------
# Core secrets (REQUIRED — the stack refuses to start without these)
# ---------------------------------------------------------------------------

# Shared HS256 signing secret used by every service AND the api-gateway.
# Must be Base64 and decode to >= 32 bytes. Generate with:  openssl rand -base64 32
JWT_SECRET=

# HMAC secret for password-reset tokens (auth-service). Generate a long random value:
#   openssl rand -hex 64
PASSWORD_RESET_HMAC_SECRET=

# Per-service Postgres passwords.
AUTH_SERVICE_DB_PASSWORD=
USER_SERVICE_DB_PASSWORD=
PAYROLL_SERVICE_DB_PASSWORD=
TIMESHEET_SERVICE_DB_PASSWORD=
CONTRACT_SERVICE_DB_PASSWORD=
PLANNING_SERVICE_DB_PASSWORD=

# SES / SMTP credentials (auth-service + contract-service email).
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Internal service-to-service auth (S1) — REQUIRED in production
# ---------------------------------------------------------------------------
# Shared secret that authenticates payroll/planning calls to user-service
# /public/** endpoints. Same value on user-service, payroll-service, planning-service.
# When blank, that hardening is disabled (fine for local dev only).
#   openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=

# ---------------------------------------------------------------------------
# First-admin bootstrap (B7) — set once to create the initial SUPER_ADMIN
# ---------------------------------------------------------------------------
# The admin is created with mustChangePassword=true and forced to rotate on first
# login. Leave blank to skip. Unset BOOTSTRAP_ADMIN_PASSWORD again after first login.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Optional / has sensible defaults
# ---------------------------------------------------------------------------
SES_SMTP_HOST=email-smtp.eu-north-1.amazonaws.com
SES_SMTP_PORT=587
SES_FROM_EMAIL=noreply@lambdamanager.com
CONTRACT_EMAIL_CONTRACT_URL=http://localhost:5173/account/employment
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password

# Browser origin allowed through the gateway (CORS).
FRONTEND_ORIGIN=http://localhost:5173

# Gateway TLS/HSTS (S5). Enable in production when TLS terminates at/above the gateway.
GATEWAY_REQUIRE_HTTPS=false
GATEWAY_HSTS_ENABLED=false
GATEWAY_HSTS_MAX_AGE=365d
